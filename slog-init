#!/bin/bash
# slog-init — Add SlugLog CLI instructions to the current project's CLAUDE.md
# Usage: Run `slog-init` in any project folder

CLAUDE_MD="CLAUDE.md"
MARKER="## Work Logging (SlugLog)"

# Check if already added
if [ -f "$CLAUDE_MD" ] && grep -q "$MARKER" "$CLAUDE_MD"; then
    echo "SlugLog instructions already in $CLAUDE_MD — skipping."
    exit 0
fi

# The block to append
SLOG_BLOCK=$(cat <<'SLOG_EOF'

## Work Logging (SlugLog)

Log your work using the `slog` command. Use timers so you don't have to guess hours.

### Timer workflow (preferred)

```bash
slog start "Task description"                          # Start timer
slog start "Task description" --project "Project Name" # With project
slog stop                                              # Stop timer, auto-logs hours
slog status                                            # Check what's running
```

- Starting a new task auto-stops and logs the previous one
- Hours are calculated from elapsed time and slug-budgeted to fit an 8h day
- Always `slog stop` before ending a session

### Quick log (when you know the hours)

```bash
slog log "What you did" 1.5
slog log "Fixed bug" 2.0 --project "Project Name" --pn 6003 --area bug
```

Areas: `programming`, `testing`, `bug`, `meeting`, `documenting`, `investigating`

### View entries

```bash
slog today    # Today's entries
slog week     # This week's summary
```
SLOG_EOF
)

if [ -f "$CLAUDE_MD" ]; then
    # Append to existing CLAUDE.md
    echo "$SLOG_BLOCK" >> "$CLAUDE_MD"
    echo "Added SlugLog instructions to existing $CLAUDE_MD"
else
    # Create new CLAUDE.md with just the slog block
    echo "# $(basename $(pwd))" > "$CLAUDE_MD"
    echo "$SLOG_BLOCK" >> "$CLAUDE_MD"
    echo "Created $CLAUDE_MD with SlugLog instructions"
fi
